# MongoDB
MONGODB_URI=mongodb://localhost:27017/presentai

# Google Gemini (required for generation endpoints)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Stock images (optional)
IMAGE_PROVIDER=pexels
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Iron Session (must match the main app cookie settings)
NEXT_PUBLIC_COOKIE_NAME=cookie
NEXT_PUBLIC_COOKIE_PASSWORD=

# App routing (nginx sub-path, if used)
NEXT_PUBLIC_API_BASE_PATH=/ai-presentation
